          color: #6b7280;
          cursor: pointer;
          transition: all 0.3s;
        }

        .nav-tab:hover {
          color: #374151;
          background: #f9fafb;
        }

        .nav-tab.active {
          color: #3b82f6;
          border-bottom-color: #3b82f6;
          background: #eff6ff;
        }

        .admin-main {
          padding: 2rem 0;
        }

        .admin-container {
          max-width: 1400px;
          margin: 0 auto;
          padding: 0 2rem;
        }

        .loading-state {
          text-align: center;
          padding: 4rem;
        }

        .loading-spinner {
          font-size: 3rem;
          margin-bottom: 1rem;
        }

        .section-title {
          font-size: 2rem;
          font-weight: 700;
          color: #1f2937;
          margin-bottom: 2rem;
        }

        .section-header {
          display: flex;
          justify-content: space-between;
          align-items: center;
          margin-bottom: 2rem;
        }

        .refresh-btn {
          padding: 0.75rem 1.5rem;
          background: #3b82f6;
          color: white;
